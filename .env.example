# ---------------------------------------------------------------------------
# Postgres (Prisma) — two URLs
#
# prisma/schema.prisma uses:
#   DATABASE_URL          → pooled / serverless-friendly (runtime queries)
#   DATABASE_URL_UNPOOLED → direct Postgres (migrations, Prisma CLI)
#
# --- Option A (recommended on Vercel): Neon via Storage / Marketplace ---
# Install Neon from Vercel → Storage → Connect. Vercel injects both vars; run:
#   vercel env pull .env.local
# (https://neon.com/docs/guides/vercel-native-integration)
#
# --- Option B: Supabase ---
# DATABASE_URL = Transaction pooler, port 6543, e.g. ?pgbouncer=true
# DATABASE_URL_UNPOOLED = Direct db.xxx.supabase.co port 5432
# Encode special characters in the password (encodeURIComponent).
#
# --- Local dev (Docker / localhost) ---
# Use the same connection string for both if you have no separate pooler:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/mydb?schema=public"
#   DATABASE_URL_UNPOOLED="postgresql://user:pass@localhost:5432/mydb?schema=public"
#
# Legacy names (optional): if set, the app maps them before connecting:
#   POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING
#
# Prisma "invalid URL / unsupported arguments": drop `options=` from the query
# string; see docs/DEPLOY.md. The app strips `options` + `channel_binding` at runtime.
# ---------------------------------------------------------------------------

DATABASE_URL="postgresql://user:password@localhost:5432/creditlyft?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/creditlyft?schema=public"

NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"
# Optional: set true on Vercel to log failed credential logins (email + whether user exists)
# LOGIN_DEBUG=true

# Email (Resend) — optional; if unset, notification emails are skipped (e.g. local dev)
RESEND_API_KEY=
EMAIL_FROM="CreditLyft Portal <onboarding@resend.dev>"

# SMS (Twilio) — optional; if unset, SMS is skipped
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Onboarding: walkthrough video (Loom or YouTube). If unset, portal tour shows icon cards.
# NEXT_PUBLIC_PORTAL_WALKTHROUGH_VIDEO=https://www.loom.com/share/xxxxx

# Onboarding: "Get Credit Monitoring" button. Defaults to MyFreeScoreNow affiliate; override if needed (opens in new tab when external URL).
# NEXT_PUBLIC_CREDIT_MONITORING_URL=https://myfreescorenow.com/enroll/?AID=...

# Supabase Storage — required for file uploads on Vercel (onboarding, Document Vault, Credit Import).
# Same project as Postgres only if you still use Supabase for DB; if Neon is your DB, keep a Supabase
# project just for Storage OR migrate to Vercel Blob later.
# Project Settings → API: copy "Project URL" and "service_role" (secret).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Billing (Stripe) — optional; if unset, pay links are hidden or placeholder
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
