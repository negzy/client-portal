# LOCAL DEV: Use DIRECT connection (Supabase port 5432).
#
# VERCEL / SERVERLESS (required): Use TRANSACTION pooler only — NOT "Session" mode.
# If you use Supabase Session pooler (or direct 5432) on Vercel, you will hit:
#   FATAL: MaxClientsInSessionMode: max clients reached - in Session mode max clients are limited to pool_size
#
# Supabase: Project Settings → Database → Connection string → pick "Transaction pooler"
# (port 6543). Example shape (password MUST be URL-encoded if it contains @ : / ? # & % +):
#   postgresql://USER:ENCODED_PASSWORD@HOST:6543/postgres?pgbouncer=true
#
# If Prisma says "The provided database string is invalid" / "arguments are not supported":
#   1) URL-encode the password only (Node: node -e "console.log(encodeURIComponent('YOUR_PASSWORD'))")
#   2) Use only one "?" in the URL; extra params use "&" (e.g. ?pgbouncer=true&connection_limit=1)
#   3) Remove stray spaces, quotes, or line breaks in Vercel env values
#   4) If Supabase gave many query params, try a minimal URL first: ...?pgbouncer=true
#
# Optional for migrations from CI: set DIRECT_DATABASE_URL to the direct (5432) URL; keep
# DATABASE_URL as the transaction pooler URL on Vercel.
DATABASE_URL="postgresql://user:password@localhost:5432/creditlyft?schema=public"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"
# Optional: set true on Vercel to log failed credential logins (email + whether user exists)
# LOGIN_DEBUG=true

# Email (Resend) — optional; if unset, notification emails are skipped (e.g. local dev)
RESEND_API_KEY=
EMAIL_FROM="CreditLyft Portal <onboarding@resend.dev>"

# SMS (Twilio) — optional; if unset, SMS is skipped
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Onboarding: walkthrough video (Loom or YouTube). If unset, portal tour shows icon cards.
# NEXT_PUBLIC_PORTAL_WALKTHROUGH_VIDEO=https://www.loom.com/share/xxxxx

# Onboarding: "Get Credit Monitoring" button. Defaults to MyFreeScoreNow affiliate; override if needed (opens in new tab when external URL).
# NEXT_PUBLIC_CREDIT_MONITORING_URL=https://myfreescorenow.com/enroll/?AID=...

# Supabase Storage — required for file uploads on Vercel (onboarding, Document Vault, Credit Import).
# Same Supabase project as DATABASE_URL. Dashboard → Storage → New bucket "portal-uploads" (public).
# Project Settings → API: copy "Project URL" and "service_role" (secret).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Billing (Stripe) — optional; if unset, pay links are hidden or placeholder
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
