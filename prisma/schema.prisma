// CreditLyft Portal - Prisma Schema
// Multi-tenant ready (future: add tenantId to key models)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Pooled/serverless runtime URL + direct URL for migrations / Prisma CLI.
  // Neon (Vercel Storage): DATABASE_URL + DATABASE_URL_UNPOOLED are injected automatically.
  // Supabase: transaction pooler → DATABASE_URL; direct :5432 → DATABASE_URL_UNPOOLED.
  // Local: set both to the same string, or only DATABASE_URL (app copies it at runtime).
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  CLIENT
  ADMIN
}

enum CreditProvider {
  MyFreeScoreNow
  IdentityIQ
  SmartCredit
  MyScoreIQ
}

enum Bureau {
  Experian
  Equifax
  TransUnion
}

enum DisputeRoundType {
  ROUND_1_BUREAU
  ROUND_2_MOV
  ROUND_3_CREDITOR
  ROUND_4_CFPB
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  WAITING
}

enum TaskCategory {
  Credit
  Funding
  Docs
  BankSetup
  Applications
  Internal
}

enum ApplicationStatus {
  PLANNED
  SUBMITTED
  PENDING
  APPROVED
  DENIED
  ON_HOLD
}

enum ApplicationType {
  CREDIT_CARD
  LINE_OF_CREDIT
  LOAN
  BUSINESS_BANKING
}

enum DocumentCategory {
  ID
  UTILITY_BILL
  SOCIAL_EIN
  LLC_DOCS
  CREDIT_REPORT
  BUREAU_RESPONSE
  DISPUTE_DOCS
  BANK_STATEMENT
  VOIDED_CHECK
  BUSINESS_VERIFICATION
  OTHER
}

enum ActivityType {
  REPORT_IMPORTED
  AUDIT_GENERATED
  NEGATIVE_ITEMS_FOUND
  ROUND_SENT
  BUREAU_RESPONDED
  ACCOUNT_REMOVED
  FUNDING_TASK_ASSIGNED
  APPLICATION_SUBMITTED
  APPROVAL_RECEIVED
  DENIAL_RECEIVED
  TASK_COMPLETED
  DOCUMENT_UPLOADED
  OTHER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  role          Role      @default(CLIENT)
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  clientProfile ClientProfile?
  assignedClients Contact[] @relation("AssignedAdmin")
  assignedProfiles ClientProfile[] @relation("AssignedAdminProfile")
  assignedTasks Task[] @relation("AssignedTo")
  createdTasks Task[] @relation("CreatedBy")
  messagesSent Message[] @relation("Sender")
  reminders Reminder[] @relation("ReminderAssignedTo")
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at       Int?
  token_type       String?
  scope             String?
  id_token          String? @db.Text
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
}

// Client profile (extends User for clients)
model ClientProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  firstName            String?  @map("first_name")
  lastName             String?  @map("last_name")
  phone                String?
  address              String?  @db.Text
  city                 String?
  state                String?
  zip                  String?
  dateOfBirth          DateTime? @map("date_of_birth")
  businessName         String?  @map("business_name")
  businessEntityType   String?  @map("business_entity_type")
  llcState             String?  @map("llc_state")
  ein                  String?  @map("ein")
  preferredContactMethod String? @map("preferred_contact_method")
  creditMonitoringEmail    String? @map("credit_monitoring_email")
  creditMonitoringUsername String? @map("credit_monitoring_username")
  creditMonitoringNotes    String? @map("credit_monitoring_notes") @db.Text
  adminNotesCfpb              String? @map("admin_notes_cfpb") @db.Text
  adminNotesCreditMonitoring  String? @map("admin_notes_credit_monitoring") @db.Text
  adminNotesEmail             String? @map("admin_notes_email") @db.Text
  notes                String?  @db.Text
  internalNotes        String?  @map("internal_notes") @db.Text
  status               String?  @default("active")
  lastActivityAt       DateTime? @map("last_activity_at")
  tags                 String[] @default([])
  assignedAdminId     String?  @map("assigned_admin_id")
  agreementSignedAt   DateTime? @map("agreement_signed_at")
  agreementDocumentUrl String? @map("agreement_document_url") @db.Text
  stripeCustomerId    String?  @map("stripe_customer_id")
  processStage        String?  @map("process_stage") // e.g. onboarding, disputing, funding
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin User? @relation("AssignedAdminProfile", fields: [assignedAdminId], references: [id])
  contact  Contact?
  creditImports CreditImport[]
  negativeItems NegativeItem[]
  audits Audit[]
  disputeRounds DisputeRound[]
  fundingReadiness FundingReadiness?
  scoreHistory ScoreHistory[]
  tasks Task[]
  applications Application[]
  documents Document[]
  inquiries InquirySnapshot[]
  timelineActivities TimelineActivity[]
  messages Message[] @relation("MessageRecipient")
  clientNotes ClientNote[]
  invoices Invoice[]
  poaRequests POARequest[]
}

model ScoreHistory {
  id              String   @id @default(cuid())
  clientProfileId String   @map("client_profile_id")
  bureau          Bureau
  score           Int
  previousScore   Int?     @map("previous_score")
  recordedAt      DateTime @default(now()) @map("recorded_at")
  source          String?  // audit, import, manual
  createdAt       DateTime @default(now()) @map("created_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Contact record (CRM) - lead or client; can link to ClientProfile when converted
model Contact {
  id              String   @id @default(cuid())
  clientProfileId String?  @unique @map("client_profile_id")
  fullName        String   @map("full_name")
  email           String
  phone           String?
  state           String?
  llcState        String?  @map("llc_state")
  businessName    String?  @map("business_name")
  notes           String?  @db.Text
  status          String?  @default("lead") // lead, contacted, qualified, converted, inactive
  source          String?  @default("web") // web, affiliate, referral
  hotness         String?  // cold, warm, hot - for lead priority
  assignedAdminId String?  @map("assigned_admin_id")
  lastActivityAt  DateTime? @map("last_activity_at")
  tags            String[] @default([])
  affiliateId     String?  @map("affiliate_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  clientProfile ClientProfile? @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  assignedAdmin User? @relation("AssignedAdmin", fields: [assignedAdminId], references: [id])
  affiliate     Affiliate? @relation(fields: [affiliateId], references: [id])
  referrals     Referral[]
}

// Credit import (credentials stored encrypted in production; MVP stores for flow)
model CreditImport {
  id                String         @id @default(cuid())
  clientProfileId   String         @map("client_profile_id")
  provider          CreditProvider
  username          String?
  passwordEnc       String?        @map("password_enc")
  securityWord      String?        @map("security_word")
  last4SSN          String?        @map("last4_ssn")
  phone             String?
  auditTemplateId   String?        @map("audit_template_id")
  status            String?        @default("pending") // pending, success, failed, manual_fallback
  rawData           Json?          @map("raw_data")
  importedAt        DateTime?      @map("imported_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Negative item from credit report
model NegativeItem {
  id              String    @id @default(cuid())
  clientProfileId String    @map("client_profile_id")
  creditImportId  String?   @map("credit_import_id")
  accountName     String    @map("account_name")
  bureau          Bureau
  accountType     String?   @map("account_type")
  balance         Decimal?  @db.Decimal(12, 2)
  accountNumber   String?   @map("account_number")
  isOpen          Boolean?  @map("is_open")
  negativeReason  String?   @map("negative_reason") @db.Text
  disputeRound    Int?      @map("dispute_round")
  currentOutcome  String?   @map("current_outcome") // removed, verified, disputed, etc.
  dateImported    DateTime  @default(now()) @map("date_imported")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  disputeRounds DisputeRoundItem[]
}

// Audit (generated PDF + summary)
model Audit {
  id                String   @id @default(cuid())
  clientProfileId   String   @map("client_profile_id")
  creditImportId    String?  @map("credit_import_id")
  auditDate         DateTime @map("audit_date")
  clientName        String   @map("client_name")
  scoreSnapshot     String?  @map("score_snapshot") // e.g. "EX: 620, EQ: 615, TU: 618"
  negativeCount     Int      @default(0) @map("negative_count")
  collectionsCount  Int      @default(0) @map("collections_count")
  chargeOffsCount   Int      @default(0) @map("charge_offs_count")
  hardInquiriesCount Int     @default(0) @map("hard_inquiries_count")
  utilizationPct    Decimal? @db.Decimal(5, 2) @map("utilization_pct")
  summaryIssues     String?  @map("summary_issues") @db.Text
  recommendedSteps  String?  @map("recommended_steps") @db.Text
  fundingReadinessScore Int? @map("funding_readiness_score")
  capitalReadinessNotes String? @map("capital_readiness_notes") @db.Text
  pdfPath           String?  @map("pdf_path")
  createdAt         DateTime @default(now()) @map("created_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Dispute round
model DisputeRound {
  id          String           @id @default(cuid())
  clientProfileId String        @map("client_profile_id")
  roundType   DisputeRoundType  @map("round_type")
  roundNumber Int              @map("round_number")
  bureau      Bureau?
  dateCreated DateTime         @default(now()) @map("date_created")
  dateSent    DateTime?        @map("date_sent")
  deliveryStatus String?       @map("delivery_status")
  outcome     String?          @db.Text
  nextStep    String?          @map("next_step") @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  items DisputeRoundItem[]
}

model DisputeRoundItem {
  id              String   @id @default(cuid())
  disputeRoundId  String   @map("dispute_round_id")
  negativeItemId  String   @map("negative_item_id")
  createdAt       DateTime @default(now()) @map("created_at")

  disputeRound DisputeRound @relation(fields: [disputeRoundId], references: [id], onDelete: Cascade)
  negativeItem NegativeItem @relation(fields: [negativeItemId], references: [id], onDelete: Cascade)

  @@unique([disputeRoundId, negativeItemId])
}

// Funding readiness
model FundingReadiness {
  id                    String   @id @default(cuid())
  clientProfileId       String   @unique @map("client_profile_id")
  score                 Int      @default(0) // 0-100
  stage                 String?  // e.g. "Credit Building", "Utilization", "Ready"
  nextActions           String?  @map("next_actions") @db.Text
  utilizationPct        Decimal? @db.Decimal(5, 2) @map("utilization_pct")
  inquiryBurden         Int?     @map("inquiry_burden")
  positiveAccountsCount Int?     @map("positive_accounts_count")
  negativeItemsCount    Int?     @map("negative_items_count")
  businessAgeMonths     Int?     @map("business_age_months")
  llcState              String?  @map("llc_state")
  businessBankingStatus String?  @map("business_banking_status")
  relationshipBanks     String[] @default([]) @map("relationship_banks")
  readyLenders          String[] @default([]) @map("ready_lenders")
  notes                 String?  @db.Text
  updatedAt             DateTime @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Task
model Task {
  id              String       @id @default(cuid())
  clientProfileId String       @map("client_profile_id")
  title           String
  description     String?      @db.Text
  status          TaskStatus   @default(NOT_STARTED)
  category        TaskCategory @default(Credit)
  dueDate         DateTime?    @map("due_date")
  notes           String?      @db.Text
  assignedById    String?      @map("assigned_by_id")
  assignedToId    String?      @map("assigned_to_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  completedAt     DateTime?    @map("completed_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("CreatedBy", fields: [assignedById], references: [id])
  assignedTo User? @relation("AssignedTo", fields: [assignedToId], references: [id])
}

// Application (funding)
model Application {
  id                  String            @id @default(cuid())
  clientProfileId     String            @map("client_profile_id")
  bankProductId       String?           @map("bank_product_id")
  bankName            String
  productName         String            @map("product_name")
  bureauPulled        Bureau?           @map("bureau_pulled")
  applicationType     ApplicationType   @map("application_type")
  dateSubmitted       DateTime?         @map("date_submitted")
  status              ApplicationStatus @default(PLANNED)
  creditRequirementNotes String?        @map("credit_requirement_notes") @db.Text
  businessRequirementNotes String?     @map("business_requirement_notes") @db.Text
  adminNotes          String?           @map("admin_notes") @db.Text
  followUpDate        DateTime?         @map("follow_up_date")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  bankProduct BankProduct? @relation(fields: [bankProductId], references: [id])
}

// Bank / Product matrix (admin)
model BankProduct {
  id                    String   @id @default(cuid())
  bankName              String   @map("bank_name")
  productName           String   @map("product_name")
  bureauPull            Bureau?  @map("bureau_pull")
  notes                 String?  @db.Text
  typicalScoreMin       Int?     @map("typical_score_min")
  typicalScoreMax       Int?     @map("typical_score_max")
  llcStatePreferences   String[] @default([]) @map("llc_state_preferences")
  relationshipBanking   Boolean  @default(false) @map("relationship_banking")
  status                String?  @default("available") // available, not_offered, on_hold, not_ready
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  applications Application[]
}

// Document (vault)
model Document {
  id              String           @id @default(cuid())
  clientProfileId String           @map("client_profile_id")
  category        DocumentCategory @default(OTHER)
  fileName        String           @map("file_name")
  filePath        String           @map("file_path")
  fileSize        Int?             @map("file_size")
  mimeType        String?          @map("mime_type")
  notes           String?          @db.Text
  uploadedAt      DateTime         @default(now()) @map("uploaded_at")
  uploadedById    String?          @map("uploaded_by_id")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Inquiry snapshot
model InquirySnapshot {
  id                String   @id @default(cuid())
  clientProfileId   String   @map("client_profile_id")
  bureau            Bureau
  inquiryCount      Int     @map("inquiry_count")
  inquiryList       Json?   @map("inquiry_list") // array of { name, date }
  notes             String? @db.Text
  cleanupStatus     String? @map("cleanup_status")
  snapshotDate      DateTime @default(now()) @map("snapshot_date")
  createdAt         DateTime @default(now()) @map("created_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Timeline / Activity
model TimelineActivity {
  id              String       @id @default(cuid())
  clientProfileId String       @map("client_profile_id")
  activityType    ActivityType  @map("activity_type")
  title           String
  description     String?      @db.Text
  metadata        Json?
  occurredAt      DateTime     @default(now()) @map("occurred_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Message (client-admin)
model Message {
  id              String   @id @default(cuid())
  senderId        String   @map("sender_id")
  recipientId     String   @map("recipient_id")
  clientProfileId String   @map("client_profile_id")
  body            String   @db.Text
  readAt          DateTime? @map("read_at")
  createdAt       DateTime @default(now()) @map("created_at")

  sender User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient ClientProfile @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

// Script / guidance (admin-created for clients)
model Script {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  category    String?  // bank_call, reconsideration, setup_instructions, capital_prep
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

// Audit template (for import flow)
model AuditTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
}

// Letter template (admin-uploaded dispute letter templates)
model LetterTemplate {
  id            String   @id @default(cuid())
  title         String
  category      String   // bureau_dispute, mov, creditor, cfpb, collection, inquiry_removal, custom
  description   String?  @db.Text
  filePath      String   @map("file_path")
  mergePlaceholders String? @map("merge_placeholders") @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  isDefault     Boolean  @default(false) @map("is_default")
  roundType     String?  @map("round_type")
  createdById   String?  @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
}

// ---------- Billing (optional use) ----------
model Invoice {
  id            String    @id @default(cuid())
  clientProfileId String   @map("client_profile_id")
  amountCents   Int       @map("amount_cents")
  currency      String    @default("usd")
  status        String    @default("draft") // draft, sent, paid, overdue, cancelled
  dueDate       DateTime? @map("due_date")
  paidAt        DateTime? @map("paid_at")
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  description   String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// ---------- Affiliates & referrals ----------
model Affiliate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  code           String   @unique // referral code
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 2)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  contacts Contact[]
  referrals Referral[]
}

model Referral {
  id             String   @id @default(cuid())
  affiliateId    String   @map("affiliate_id")
  contactId      String   @map("contact_id")
  status         String   @default("pending") // pending, converted, paid
  commissionAmountCents Int? @map("commission_amount_cents")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

// ---------- White-label / portal settings (single row) ----------
model PortalSettings {
  id          String   @id @default(cuid())
  siteName    String   @map("site_name") @default("CreditLyft")
  logoUrl     String?  @map("logo_url") @db.Text
  primaryColor String? @map("primary_color") @default("#f97316")
  faviconUrl  String?  @map("favicon_url") @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")
}

// ---------- POA (Power of Attorney) - optional flow ----------
model POARequest {
  id              String    @id @default(cuid())
  clientProfileId String    @map("client_profile_id")
  status          String    @default("requested") // requested, in_progress, completed, expired
  requestedAt     DateTime @default(now()) @map("requested_at")
  completedAt     DateTime? @map("completed_at")
  documentUrl     String?   @map("document_url") @db.Text
  notes           String?   @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// ---------- Internal notes per client (DisputeFox-style) ----------
model ClientNote {
  id              String   @id @default(cuid())
  clientProfileId String   @map("client_profile_id")
  authorId        String   @map("author_id") // User id
  body            String   @db.Text
  isPinned        Boolean  @default(false) @map("is_pinned")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// ---------- Reminders (calendar-style) ----------
model Reminder {
  id              String    @id @default(cuid())
  clientProfileId String?   @map("client_profile_id")
  assignedToId    String    @map("assigned_to_id")
  title           String
  body            String?   @db.Text
  dueAt           DateTime  @map("due_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignedTo User @relation("ReminderAssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)
}

// ---------- Workflow / email campaign (automation) ----------
model Workflow {
  id          String   @id @default(cuid())
  name        String
  trigger     String   // e.g. onboarding, new_lead, score_updated
  steps       Json     // [{ delayDays, subject, body }]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

// ---------- Dispute libraries (instructions, creditors, furnishers) ----------
model DisputeInstruction {
  id       String   @id @default(cuid())
  name     String
  body     String   @db.Text
  category String?  // bureau, creditor, general
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Creditor {
  id      String   @id @default(cuid())
  name    String
  address String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Furnisher {
  id      String   @id @default(cuid())
  name    String
  address String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

// Admin / VA notes (credentials: CFPB, FTC, etc.)
model AdminNote {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. CFPB, FTC, general
  label     String   // Display name
  content   String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
}
